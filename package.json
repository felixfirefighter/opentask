{
  "name": "omplish",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "A local-first task and planning workspace",
  "author": "Rarticle Software Sdn. Bhd.",
  "license": "AGPL-3.0-or-later",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:electron": "next build --webpack",
    "start": "next start",
    "electron:compile": "node scripts/compile-electron.mjs",
    "electron:stage-runtime": "node scripts/stage-desktop-runtime.mjs",
    "electron:prepare": "node node_modules/electron/install.js",
    "electron:dev": "pnpm db:up && pnpm db:migrate && pnpm electron:compile && node --env-file-if-exists=.env.local node_modules/electron/cli.js . --dev",
    "electron:build": "pnpm build:electron && pnpm electron:compile",
    "electron:check-runtime": "node --experimental-strip-types electron/check-runtime.ts",
    "electron:check-package": "node scripts/check-desktop-package.mjs",
    "electron:runtime-smoke": "node scripts/smoke-desktop-runtime.mjs",
    "electron:smoke": "node scripts/smoke-desktop.mjs",
    "electron:prepare-package": "node scripts/prepare-desktop-package.mjs",
    "electron:dist": "pnpm electron:build && pnpm electron:check-runtime && pnpm electron:prepare-package && node scripts/build-desktop.mjs",
    "electron:dist:release": "pnpm electron:build && pnpm electron:check-runtime && pnpm electron:prepare-package && node scripts/build-desktop.mjs --config electron-builder.release.yml",
    "electron:dist:dir": "pnpm electron:build && pnpm electron:check-runtime && pnpm electron:prepare-package && node scripts/build-desktop.mjs --dir",
    "worker": "node --env-file-if-exists=.env.local --experimental-strip-types worker/index.ts",
    "worker:smoke": "pnpm worker -- --check",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/seed.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "test:boundaries": "node scripts/check-boundaries.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:audit": "pnpm audit --prod --audit-level high",
    "check:design": "node scripts/check-design-contract.mjs",
    "typecheck": "node scripts/prepare-typecheck.mjs && next typegen && tsc --noEmit && tsc -p tsconfig.node.json && tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "test:db": "node --env-file-if-exists=.env.local ./node_modules/vitest/vitest.mjs run --config vitest.db.config.ts",
    "test:e2e": "pnpm test:e2e:core && pnpm test:e2e:planner-fixture",
    "test:e2e:core": "playwright test tests/e2e/visual-proof.spec.ts tests/e2e/health.spec.ts tests/e2e/wp01-identity-shell.spec.ts tests/e2e/wp03-core-task-loop.spec.ts tests/e2e/wp03-task-recovery.spec.ts tests/e2e/g2-plan-across-time.spec.ts tests/e2e/g3-reality-aware-plan.spec.ts tests/e2e/g4-portable-export.spec.ts",
    "test:e2e:planner-fixture": "PLAYWRIGHT_PLANNER_FIXTURE=1 playwright test tests/e2e/g3-reality-aware-plan.spec.ts --project=desktop-chromium --project=mobile-chromium",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "test:design": "playwright test tests/e2e/design-contract.spec.ts",
    "test:production": "node scripts/check-production-topology.mjs",
    "verify:quick": "pnpm format:check && pnpm lint && pnpm test:boundaries && pnpm typecheck && pnpm check:design && pnpm check:secrets && pnpm test",
    "verify:design": "pnpm check:design && pnpm test:design",
    "verify": "pnpm verify:quick && pnpm db:migrate && pnpm test:db && pnpm worker:smoke && pnpm build && PLAYWRIGHT_SERVER_MODE=production pnpm test:design && PLAYWRIGHT_SERVER_MODE=production pnpm test:e2e && PLAYWRIGHT_SERVER_MODE=production pnpm test:a11y && pnpm check:licenses && pnpm check:audit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fullcalendar/react": "7.0.1",
    "@radix-ui/react-alert-dialog": "1.1.19",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-slot": "1.3.0",
    "@tanstack/react-query": "5.101.2",
    "better-auth": "1.6.23",
    "chrono-node": "2.10.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "drizzle-orm": "0.45.2",
    "fractional-indexing": "4.0.0",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "openai": "6.48.0",
    "pg": "8.22.0",
    "pg-boss": "12.26.1",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "temporal-polyfill": "1.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "0.31.10",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-boundaries": "7.0.2",
    "jsdom": "29.1.1",
    "next-devtools-mcp": "0.4.0",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
