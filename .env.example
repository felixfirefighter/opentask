# Local host processes connect through the published PostgreSQL port.
DATABASE_URL=postgresql://opentask:opentask-local@127.0.0.1:54329/opentask
TEST_DATABASE_URL=postgresql://opentask:opentask-local@127.0.0.1:54329/opentask_test
LOG_LEVEL=info

# Optional providers are introduced by later work packages. Keep keys server-side.
OPENAI_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
