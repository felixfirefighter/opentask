# Local host processes connect through the published PostgreSQL port.
DATABASE_URL=postgresql://opentask:opentask-local@127.0.0.1:54329/opentask
TEST_DATABASE_URL=postgresql://opentask:opentask-local@127.0.0.1:54329/opentask_test
LOG_LEVEL=info

# Generate a unique secret with `openssl rand -base64 32` before deployment.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Exact browser-facing origin. Localhost and 127.0.0.1 are same-scheme/same-port aliases only.
# See SECURITY.md before placing the app behind a proxy; non-loopback origins never expand.
BETTER_AUTH_URL=http://127.0.0.1:3000

# Optional planner provider. Keep this server-side; manual workflows do not require it.
OPENAI_API_KEY=

# Optional browser reminders. `disabled` is an honest local default; set `enabled` only when the
# separate worker process is supervised. VAPID values are all-or-none. Encryption values are
# all-or-none; keyring entries are comma-separated
# `<nonnegative-version>:<43-character-base64url-key>` pairs with unique versions. The active
# version must match exactly one entry.
REMINDER_WORKER_MODE=disabled
WEB_PUSH_VAPID_SUBJECT=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
PUSH_SUBSCRIPTION_ACTIVE_KEY_VERSION=
PUSH_SUBSCRIPTION_ENCRYPTION_KEYS=
