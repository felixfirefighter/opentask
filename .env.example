# Local host processes connect through the published PostgreSQL port.
DATABASE_URL=postgresql://opentask:opentask-local@127.0.0.1:54329/opentask
TEST_DATABASE_URL=postgresql://opentask:opentask-local@127.0.0.1:54329/opentask_test
LOG_LEVEL=info

# Generate a unique secret with `openssl rand -base64 32` before deployment.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Exact browser-facing origin. See SECURITY.md before placing the app behind a proxy.
BETTER_AUTH_URL=http://127.0.0.1:3000

# Optional providers are introduced by later work packages. Keep keys server-side.
OPENAI_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
